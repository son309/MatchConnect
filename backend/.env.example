##############################################
# BACKEND ENVIRONMENT VARIABLES (.env.production)
##############################################

# Server Configuration
NODE_ENV=production
PORT=3000

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dating_db

# Frontend URL (IMPORTANT: Update after frontend deployment)
CLIENT_URL=https://frontend-app.eastus.azurecontainerapps.io

# Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long

# Email Service (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Image Upload (Cloudinary)
CLOUDINARY_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=123456789000000
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# Email Configuration (Nodemailer - Optional if using Resend)
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# Security (Arcjet)
ARCJET_KEY=ajkey_xxxxxxxxxxxxxxxxxxxxxxxx
ARCJET_ENV=production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session/Cookie
COOKIE_SECRET=your-cookie-secret-key-here

# Additional Services
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Logging
LOG_LEVEL=info
